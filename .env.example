# 🌈 Local template defaults
# Copy this file to `.env` only when you want to override the defaults.

# 🦍 Kong local ports
KONG_PROXY_PORT=8000
KONG_PROXY_SSL_PORT=8443
KONG_ADMIN_PORT=8001
KONG_STATUS_PORT=8100

# 🔐 Keycloak local IdP
KEYCLOAK_PORT=18080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# 🧱 Native plugin build toggle
# Keep false unless your runtime Kong image must compile native code during `docker compose build`.
INSTALL_NATIVE_BUILD_DEPS=false
