    },
    {
      "name": "JSON guard - valid payload is proxied",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"customer_id\":\"cust-123\",\"action\":\"signup\"}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{proxy_url}}/guarded/post"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "function headerValue(headers, name) {",
              "  const wanted = name.toLowerCase();",
              "  const key = Object.keys(headers || {}).find(function (candidate) {",
              "    return candidate.toLowerCase() === wanted;",
              "  });",
              "  return key ? headers[key] : undefined;",
              "}",
              "",
              "pm.test(\"valid JSON is proxied\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test(\"guard stripped /guarded and upstream received JSON\", function () {",
              "  pm.expect(body.path).to.eql(\"/post\");",
              "  pm.expect(body.json.customer_id).to.eql(\"cust-123\");",
              "  pm.expect(body.json.action).to.eql(\"signup\");",
              "});",
              "",
              "pm.test(\"upstream received guard pass header\", function () {",
              "  pm.expect(headerValue(body.headers, \"X-Json-Guard\")).to.eql(\"passed\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "JSON guard - missing required field is rejected",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"customer_id\":\"cust-123\"}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{proxy_url}}/guarded/post"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"missing required field returns 422\", function () {",
              "  pm.response.to.have.status(422);",
              "});",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test(\"response names the missing field\", function () {",
              "  pm.expect(body.message).to.eql(\"Required JSON fields are missing\");",
              "  pm.expect(body.missing).to.include(\"action\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "JSON guard - forbidden key is rejected",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"customer_id\":\"cust-123\",\"action\":\"signup\",\"password\":\"secret\"}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{proxy_url}}/guarded/post"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"forbidden key returns 422\", function () {",
              "  pm.response.to.have.status(422);",
              "});",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test(\"response names the forbidden key\", function () {",
              "  pm.expect(body.message).to.eql(\"Forbidden JSON fields are present\");",
              "  pm.expect(body.forbidden).to.include(\"password\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "JSON guard - non-JSON payload is rejected",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "text/plain"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "customer_id=cust-123&action=signup"
        },
        "url": "{{proxy_url}}/guarded/post"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"non-JSON payload returns 415\", function () {",
              "  pm.response.to.have.status(415);",
              "});",
              "",
              "pm.test(\"response explains that JSON is required\", function () {",
              "  pm.expect(pm.response.json().message).to.eql(\"JSON payload required\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
